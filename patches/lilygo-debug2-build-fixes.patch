diff --git a/main/CMakeLists.txt b/main/CMakeLists.txt
index 259c124..8abcec7 100644
--- a/main/CMakeLists.txt
+++ b/main/CMakeLists.txt
@@ -69,5 +69,21 @@ elseif(CONFIG_EXAMPLE_BUILD_USB_HOST_MSC)
     set(project_path "examples/usb_host_msc/")
 endif()
 
-idf_component_register(SRC_DIRS ${project_path} 
+idf_component_register(SRC_DIRS ${project_path}
                         INCLUDE_DIRS ${project_path})
+
+# The debug2 branch examples consume SCREEN_WIDTH/SCREEN_HEIGHT/SCREEN_BITS_PER_PIXEL
+# and CONFIG_SCREEN_TYPE_*, but the screen-type Kconfig choice was dropped mid-refactor.
+# Values mirror libraries/lilygo_device_driver/.../t_display_p4_config.h.
+if(CONFIG_SCREEN_PIXEL_FORMAT_RGB888)
+    set(screen_bpp 24)
+else()
+    set(screen_bpp 16)
+endif()
+if(CONFIG_SCREEN_TYPE_HI8561)
+    target_compile_definitions(${COMPONENT_LIB} PRIVATE
+        SCREEN_WIDTH=540 SCREEN_HEIGHT=1168 SCREEN_BITS_PER_PIXEL=${screen_bpp})
+elseif(CONFIG_SCREEN_TYPE_RM69A10)
+    target_compile_definitions(${COMPONENT_LIB} PRIVATE
+        SCREEN_WIDTH=568 SCREEN_HEIGHT=1232 SCREEN_BITS_PER_PIXEL=${screen_bpp})
+endif()
diff --git a/main/Kconfig.projbuild b/main/Kconfig.projbuild
index f03d4ca..d9eee46 100644
--- a/main/Kconfig.projbuild
+++ b/main/Kconfig.projbuild
@@ -20,6 +20,15 @@ menu "Example Configuration"
                 bool "RGB888"
     endchoice
 
+    choice
+        prompt "Select the screen type"
+        default SCREEN_TYPE_HI8561
+            config SCREEN_TYPE_HI8561
+                bool "HI8561 (TFT 540x1168)"
+            config SCREEN_TYPE_RM69A10
+                bool "RM69A10 (AMOLED 568x1232)"
+    endchoice
+
     choice
         prompt "Select the color format of the camera"
         default CAMERA_PIXEL_FORMAT_RGB565
diff --git a/main/examples/esp32c6_at_host_sdio_uart/main.cpp b/main/examples/esp32c6_at_host_sdio_uart/main.cpp
index 07dee43..fc87821 100644
--- a/main/examples/esp32c6_at_host_sdio_uart/main.cpp
+++ b/main/examples/esp32c6_at_host_sdio_uart/main.cpp
@@ -13,17 +13,23 @@ extern "C" void app_main(void) {
   auto& driver = lilygo_device_driver::TDisplayP4Driver::GetInstance();
   driver.Init();
 
+  // debug2 API: pin constants moved into lilygo_device_driver::t_display_p4::gpio
+  namespace gpio = lilygo_device_driver::t_display_p4::gpio;
+
   auto esp32c6_at_sdio_bus = std::make_shared<cpp_bus_driver::HardwareSdio>(
-      ESP32C6_SDIO_CLK, ESP32C6_SDIO_CMD, ESP32C6_SDIO_D0, ESP32C6_SDIO_D1,
-      ESP32C6_SDIO_D2, ESP32C6_SDIO_D3, -1, -1, -1, -1,
-      cpp_bus_driver::HardwareSdio::SdioPort::kSlot1);
+      gpio::esp32c6::kSdioClk, gpio::esp32c6::kSdioCmd, gpio::esp32c6::kSdioD0,
+      gpio::esp32c6::kSdioD1, gpio::esp32c6::kSdioD2, gpio::esp32c6::kSdioD3,
+      -1, -1, -1, -1, cpp_bus_driver::HardwareSdio::SdioPort::kSlot1);
 
   auto esp32c6_at = std::make_unique<cpp_bus_driver::EspAt>(
       esp32c6_at_sdio_bus, [](bool value) -> void {
-        // ESP32C6复位
-        driver.chip().xl9535->GpioWrite(
-            XL9535_ESP32C6_EN,
-            static_cast<cpp_bus_driver::Xl95x5::Value>(value));
+        // ESP32C6复位 (capture-less: ctor takes a plain function pointer;
+        // the driver is a singleton anyway)
+        lilygo_device_driver::TDisplayP4Driver::GetInstance()
+            .chip()
+            .xl9535->GpioWrite(
+                lilygo_device_driver::t_display_p4::gpio::xl9535::kEsp32c6En,
+                static_cast<cpp_bus_driver::Xl95x5::Value>(value));
       });
 
   esp32c6_at->Init();
