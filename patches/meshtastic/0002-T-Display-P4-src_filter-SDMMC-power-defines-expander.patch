From a6779b5321f5e18e7d71a65b09290d25199ae8b2 Mon Sep 17 00:00:00 2001
From: Mikhail-Za <86077672+Mikhail-Za@users.noreply.github.com>
Date: Fri, 12 Jun 2026 11:13:36 -0500
Subject: [PATCH 2/5] T-Display P4: src_filter, SDMMC power defines, expander
 init + SX1262 reset pulse

Co-Authored-By: Claude Fable 5 <noreply@anthropic.com>
---
 protobufs                                    |  2 +-
 variants/esp32p4/t-display-p4/platformio.ini |  6 ++++++
 variants/esp32p4/t-display-p4/variant.cpp    | 11 ++++++++++-
 variants/esp32p4/t-display-p4/variant.h      |  7 +++++--
 4 files changed, 22 insertions(+), 4 deletions(-)

diff --git a/protobufs b/protobufs
index 8b68f2736..485ede742 160000
--- a/protobufs
+++ b/protobufs
@@ -1 +1 @@
-Subproject commit 8b68f273671ed3bca7c0bb8596f0f082232fae63
+Subproject commit 485ede7422e6db2c819e42913167ab15d9f557b7
diff --git a/variants/esp32p4/t-display-p4/platformio.ini b/variants/esp32p4/t-display-p4/platformio.ini
index 26cd52967..47708b1af 100644
--- a/variants/esp32p4/t-display-p4/platformio.ini
+++ b/variants/esp32p4/t-display-p4/platformio.ini
@@ -18,6 +18,10 @@ platform_packages =
   ; ng-io-expander core: routes (pin | IO_EXPANDER) GPIO calls through the XL9535
   platformio/framework-arduinoespressif32 @ https://github.com/mverch67/arduino-esp32#82aee17619ea2940de03b0db4d082d5def657771
 
+build_src_filter =
+  ${esp32p4_base.build_src_filter}
+  +<../variants/esp32p4/t-display-p4>
+
 build_flags = ${esp32p4_base.build_flags}
   -Ivariants/esp32p4/t-display-p4
   -DTDISPLAY_P4
@@ -25,6 +29,8 @@ build_flags = ${esp32p4_base.build_flags}
   -DIO_EXPANDER_IRQ=5
   -DUSE_ARDUINO_HAL_GPIO
   -DFS_PARTITION_LABEL=\"mesh_fs\"
+  -DRADIOLIB_DEBUG_BASIC=1
+  -DRADIOLIB_DEBUG_SPI=1
 
 ; The ng-io-expander fork's idf_component.yml has a broken P4-conditional rule
 ; requesting espressif/cbor ^2.0.12 (no such version exists; cbor is only used
diff --git a/variants/esp32p4/t-display-p4/variant.cpp b/variants/esp32p4/t-display-p4/variant.cpp
index 807ca9875..9ee1b687e 100644
--- a/variants/esp32p4/t-display-p4/variant.cpp
+++ b/variants/esp32p4/t-display-p4/variant.cpp
@@ -63,7 +63,16 @@ extern "C" void initVariant(void)
         esp_io_expander_set_level(io_expander, 1 << 1, 1);  // RF1 antenna path
         esp_io_expander_set_level(io_expander, 1 << 0, 0);  // 3V3 rail (low = on)
         esp_io_expander_set_level(io_expander, 1 << 6, 1);  // 5V rail on
-        esp_io_expander_set_level(io_expander, 1 << 14, 1); // SX1262 out of reset
+        // Hardware-reset the SX1262 so it never inherits stale state from a
+        // previously booted firmware (dual-boot: MeshOS may have left it
+        // mid-RX with different settings).
+        esp_io_expander_set_level(io_expander, 1 << 14, 0);
+        delay(5);
+        esp_io_expander_set_level(io_expander, 1 << 14, 1); // out of reset
+        delay(20);
         // DIO1 (bit 15) stays input; core pinMode handles it via attachInterrupt
     }
+
+    // SX1262 BUSY: LilyGo's reference example configures it with a pulldown
+    pinMode(6, INPUT_PULLDOWN);
 }
diff --git a/variants/esp32p4/t-display-p4/variant.h b/variants/esp32p4/t-display-p4/variant.h
index c2990ba35..25425186d 100644
--- a/variants/esp32p4/t-display-p4/variant.h
+++ b/variants/esp32p4/t-display-p4/variant.h
@@ -37,8 +37,11 @@
 
 #define SX126X_CS LORA_CS
 #define SX126X_BUSY 6
-#define SX126X_RESET (14 | IO_EXPANDER) // XL9535 "IO16" = register bit 14
-#define SX126X_DIO1 (15 | IO_EXPANDER)  // XL9535 "IO17" = register bit 15
+// Reset is wired to XL9535 bit 14, but we leave it to the variant init /
+// launcher (held high = out of reset) and skip RadioLib's hardware reset,
+// matching LilyGo's own radiolib example (Module reset = RADIOLIB_NC).
+#define SX126X_RESET RADIOLIB_NC
+#define SX126X_DIO1 (15 | IO_EXPANDER) // XL9535 "IO17" = register bit 15
 #define SX126X_MAX_POWER 22
 // NOTE: no SX126X_DIO2_AS_RF_SWITCH and no TCXO — matches LilyGo's own
 // radiolib_sx1262_send_receive example for this board.
-- 
