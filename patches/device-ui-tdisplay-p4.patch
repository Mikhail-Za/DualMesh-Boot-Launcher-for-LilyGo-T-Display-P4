+// ---------------------------------------------------------------------------
+// Touch: HI8561 touch controller @0x68 on the shared i2c_master bus.
+// Protocol: write {0xF3, addr32_be, 0x03} then read N bytes (memory-mapped).
+// Discovery: info block at ESRAM section table; points at +3, 5 bytes each:
+// X be16, Y be16, pressure u8. (Port of LilyGo cpp_bus_driver hi8561_touch.)
+// ---------------------------------------------------------------------------
+class Touch_HI8561 : public ITouch
+{
+    static constexpr uint32_t kEram = 0x20011000;
+    static constexpr uint32_t kEsramSectionInfo = kEram + 4 + 25 * 8 + 4;
+    static constexpr uint8_t kMaxFingers = 5;
+
+  public:
+    bool init(void) override
+    {
+        if (_inited)
+            return true;
+        if (tdp4_i2c_bus == nullptr)
+            return false;
+        i2c_device_config_t dev_cfg = {};
+        dev_cfg.dev_addr_length = I2C_ADDR_BIT_LEN_7;
+        dev_cfg.device_address = 0x68;
+        dev_cfg.scl_speed_hz = 400000;
+        if (i2c_master_bus_add_device(tdp4_i2c_bus, &dev_cfg, &_dev) != ESP_OK)
+            return false;
+        uint8_t info[48] = {0};
+        if (!memRead(kEsramSectionInfo, info, sizeof(info)))
+            return false;
+        _touch_info_addr = info[8] | (info[9] << 8) | (info[10] << 16) | ((uint32_t)info[11] << 24);
+        if (_touch_info_addr < kEram || _touch_info_addr >= kEram + 4096) {
+            ESP_LOGE("TDP4", "touch info addr invalid: 0x%08lx", (unsigned long)_touch_info_addr);
+            _touch_info_addr = 0;
+            return false;
+        }
+        ESP_LOGI("TDP4", "touch up, info addr 0x%08lx", (unsigned long)_touch_info_addr);
+        _inited = true;
+        return true;
+    }
+
+    void wakeup(void) override {}
+    void sleep(void) override {}
+
+
+    uint_fast8_t getTouchRaw(touch_point_t *tp, uint_fast8_t count) override
+    {
+        if (!_inited || _touch_info_addr == 0)
+            return 0;
+        uint8_t buf[3 + kMaxFingers * 5] = {0};
+        if (!memRead(_touch_info_addr, buf, sizeof(buf)))
+            return 0;
+        uint8_t fingers = buf[0];
+        if (fingers == 0 || fingers > kMaxFingers)
+            return 0;
+        if (count > fingers)
+            count = fingers;
+        uint_fast8_t got = 0;
+        for (uint_fast8_t i = 0; i < count; ++i) {
+            const uint8_t *p = &buf[3 + i * 5];
+            uint16_t x = (p[0] << 8) | p[1];
+            uint16_t y = (p[2] << 8) | p[3];
+            if (x == 0xFFFF && y == 0xFFFF)
+                continue;
+            // native 1:1 — touch coordinates already match the LVGL surface
+            tp[got].x = x < TDP4_PANEL_W ? x : TDP4_PANEL_W - 1;
+            tp[got].y = y < TDP4_PANEL_H ? y : TDP4_PANEL_H - 1;
+            tp[got].size = p[4] ? p[4] : 1;
+            tp[got].id = got;
+            ++got;
+        }
+        return got;
+    }
+
+  private:
+    bool memRead(uint32_t addr, uint8_t *out, size_t len)
+    {
+        uint8_t cmd[6] = {0xF3, (uint8_t)(addr >> 24), (uint8_t)(addr >> 16), (uint8_t)(addr >> 8), (uint8_t)addr, 0x03};
+        return i2c_master_transmit_receive(_dev, cmd, sizeof(cmd), out, len, 100) == ESP_OK;
+    }
+
+    i2c_master_dev_handle_t _dev = nullptr;
+    uint32_t _touch_info_addr = 0;
+    bool _inited = false;
+};
+
