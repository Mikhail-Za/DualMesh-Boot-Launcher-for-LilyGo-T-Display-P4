+// ---------------------------------------------------------------------------
+// The LGFX device
+// ---------------------------------------------------------------------------
+class LGFX_TDISPLAY_P4 : public lgfx::LGFX_Device
+{
+    lgfx::Bus_DSI_P4 _bus_instance;
+    lgfx::Panel_DSI_P4 _panel_instance;
+    lgfx::Light_TDP4 _light_instance;
+    lgfx::Touch_HI8561 _touch_instance;
+
+  public:
+    const uint32_t screenWidth = TDP4_LOGICAL_W;
+    const uint32_t screenHeight = TDP4_LOGICAL_H;
+
+    bool hasButton(void) { return false; }
+
+    // Swap the composed back buffer on screen (called from the LVGL flush path
+    // after the last dirty area of a frame). Double-buffered, vsync-synced.
+    void present(void) { _panel_instance.present(); }
+
+    LGFX_TDISPLAY_P4(void)
+    {
+        {
+            auto cfg = _panel_instance.config();
+            cfg.memory_width = TDP4_LOGICAL_W;
+            cfg.memory_height = TDP4_LOGICAL_H;
+            cfg.panel_width = TDP4_LOGICAL_W;
+            cfg.panel_height = TDP4_LOGICAL_H;
+            cfg.readable = true;
+            cfg.rgb_order = false;
+            cfg.bus_shared = false;
+            cfg.offset_x = 0;
+            cfg.offset_y = 0;
+            cfg.offset_rotation = 0;
+            cfg.pin_cs = -1;
+            cfg.pin_rst = -1; // reset handled by initVariant via XL9535
+            _panel_instance.config(cfg);
+        }
+        _panel_instance.setBus(&_bus_instance);
+        _panel_instance.setLight(&_light_instance);
+
+        {
+            auto cfg = _touch_instance.config();
+            cfg.x_min = 0;
+            cfg.y_min = 0;
+            cfg.x_max = TDP4_LOGICAL_W - 1;
+            cfg.y_max = TDP4_LOGICAL_H - 1;
+            cfg.pin_int = -1;
+            cfg.pin_rst = -1; // reset handled by initVariant via XL9535
+            cfg.bus_shared = true;
+            cfg.offset_rotation = 0;
+            _touch_instance.config(cfg);
+        }
+        _panel_instance.setTouch(&_touch_instance);
+        setPanel(&_panel_instance);
+    }
+};
