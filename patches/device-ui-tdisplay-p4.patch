+// ---------------------------------------------------------------------------
+// Bus: owns LDO + DSI bus + DBI io (panel init) + DPI panel (scanout). The
+// only thing LGFX uses afterwards is the framebuffer pointer.
+// ---------------------------------------------------------------------------
+class Bus_DSI_P4 : public IBus
+{
+  public:
+    bus_type_t busType(void) const override { return bus_type_t::bus_unknown; }
+
+    bool init(void) override
+    {
+        if (_fbs[0])
+            return true;
+
+        esp_ldo_channel_config_t ldo_cfg = {};
+        ldo_cfg.chan_id = 3;
+        ldo_cfg.voltage_mv = 1830; // LilyGo runs the MIPI domain at 1.8V
+        if (_ldo == nullptr && esp_ldo_acquire_channel(&ldo_cfg, &_ldo) != ESP_OK) {
+            ESP_LOGE("TDP4", "MIPI PHY LDO acquire failed");
+            return false;
+        }
+        vTaskDelay(pdMS_TO_TICKS(10));
+
+        esp_lcd_dsi_bus_config_t bus_cfg = {};
+        bus_cfg.bus_id = 0;
+        bus_cfg.num_data_lanes = 2;
+        bus_cfg.phy_clk_src = MIPI_DSI_PHY_CLK_SRC_DEFAULT;
+        bus_cfg.lane_bit_rate_mbps = 1000;
+        if (esp_lcd_new_dsi_bus(&bus_cfg, &_dsi_bus) != ESP_OK) {
+            ESP_LOGE("TDP4", "dsi bus create failed");
+            return false;
+        }
+
+        esp_lcd_dbi_io_config_t io_cfg = {};
+        io_cfg.virtual_channel = 0;
+        io_cfg.lcd_cmd_bits = 8;
+        io_cfg.lcd_param_bits = 8;
+        if (esp_lcd_new_panel_io_dbi(_dsi_bus, &io_cfg, &_io) != ESP_OK) {
+            ESP_LOGE("TDP4", "dbi io create failed");
+            return false;
+        }
+
+        // Vendor init (panel was hardware-reset by initVariant via XL9535)
+        for (size_t i = 0; i < sizeof(HI8561_INIT);) {
+            uint8_t cmd = HI8561_INIT[i];
+            if (cmd == 0xFF) {
+                vTaskDelay(pdMS_TO_TICKS(HI8561_INIT[i + 1]));
+                i += 2;
+                continue;
+            }
+            uint8_t len = HI8561_INIT[i + 1];
+            if (esp_lcd_panel_io_tx_param(_io, cmd, len ? &HI8561_INIT[i + 2] : nullptr, len) != ESP_OK) {
+                ESP_LOGE("TDP4", "init cmd 0x%02x failed", cmd);
+                return false;
+            }
+            i += 2 + len;
+        }
+
+        esp_lcd_dpi_panel_config_t dpi_cfg = {};
+        dpi_cfg.virtual_channel = 0;
+        dpi_cfg.dpi_clk_src = MIPI_DSI_DPI_CLK_SRC_DEFAULT;
+        dpi_cfg.dpi_clock_freq_mhz = 60;
+        dpi_cfg.pixel_format = LCD_COLOR_PIXEL_FORMAT_RGB565;
+        dpi_cfg.num_fbs = 1;
+        dpi_cfg.video_timing.h_size = TDP4_PANEL_W;
+        dpi_cfg.video_timing.v_size = TDP4_PANEL_H;
+        dpi_cfg.video_timing.hsync_pulse_width = 28;
+        dpi_cfg.video_timing.hsync_back_porch = 26;
+        dpi_cfg.video_timing.hsync_front_porch = 20;
+        dpi_cfg.video_timing.vsync_pulse_width = 2;
+        dpi_cfg.video_timing.vsync_back_porch = 22;
+        dpi_cfg.video_timing.vsync_front_porch = 200;
+        dpi_cfg.num_fbs = 2; // double buffer: compose into the off-screen fb, swap on vsync
+        dpi_cfg.flags.use_dma2d = true;
+        if (esp_lcd_new_panel_dpi(_dsi_bus, &dpi_cfg, &_panel) != ESP_OK) {
+            ESP_LOGE("TDP4", "dpi panel create failed");
+            return false;
+        }
+        if (esp_lcd_panel_init(_panel) != ESP_OK) {
+            ESP_LOGE("TDP4", "dpi panel init failed");
+            return false;
+        }
+        void *fb0 = nullptr, *fb1 = nullptr;
+        if (esp_lcd_dpi_panel_get_frame_buffer(_panel, 2, &fb0, &fb1) != ESP_OK || fb0 == nullptr || fb1 == nullptr) {
+            ESP_LOGE("TDP4", "get framebuffer failed");
+            return false;
+        }
+        _fbs[0] = static_cast<uint8_t *>(fb0);
+        _fbs[1] = static_cast<uint8_t *>(fb1);
+        // The driver starts scanning fb[0] (cur_fb_index = 0), so fb[1] is the
+        // first off-screen buffer we compose into.
+        _back = 1;
+        _vsync = xSemaphoreCreateBinary();
+        esp_lcd_dpi_panel_event_callbacks_t cbs = {};
+        cbs.on_refresh_done = &Bus_DSI_P4::onRefreshDone;
+        esp_err_t cb_err = esp_lcd_dpi_panel_register_event_callbacks(_panel, &cbs, this);
+        if (cb_err != ESP_OK)
+            ESP_LOGE("TDP4", "vsync cb register failed: %d (present() will fall back to timeout)", cb_err);
+        ESP_LOGI("TDP4", "DSI panel up, fb0=%p fb1=%p (double-buffered)", fb0, fb1);
+        return true;
+    }
+
+    // Off-screen buffer the panel is NOT currently scanning — LVGL composes here.
+    uint16_t *backbuf(void) { return reinterpret_cast<uint16_t *>(_fbs[_back]); }
+
+    // Present the composed frame: a draw_bitmap whose source IS one of the
+    // driver's framebuffers is a zero-copy vsync swap (esp_lcd_panel_dpi.c),
+    // so the new frame appears atomically at the next frame boundary — no tear.
+    // Then wait until that frame is actually on screen before flipping, so we
+    // never compose into a buffer that is still being scanned out.
+    void present(void)
+    {
+        if (_panel == nullptr)
+            return;
+        if (_vsync)
+            xSemaphoreTake(_vsync, 0); // drop any stale refresh-done from a prior frame
+        esp_lcd_panel_draw_bitmap(_panel, 0, 0, TDP4_PANEL_W, TDP4_PANEL_H, _fbs[_back]);
+        // Wait for the next refresh-done: the buffer we just swapped in is now on
+        // screen, so the other buffer is free to compose into. ~1 frame (16ms) at
+        // 60Hz; the short timeout caps the stall if the vsync cb ever drops.
+        if (_vsync)
+            xSemaphoreTake(_vsync, pdMS_TO_TICKS(25));
+        _back ^= 1;
+    }
+
+    void release(void) override {}
+    void beginTransaction(void) override {}
+    void endTransaction(void) override {}
+    void wait(void) override {}
+    bool busy(void) const override { return false; }
+    void flush(void) override {}
+    bool writeCommand(uint32_t, uint_fast8_t) override { return true; }
+    void writeData(uint32_t, uint_fast8_t) override {}
+    void writeDataRepeat(uint32_t, uint_fast8_t, uint32_t) override {}
+    void writePixels(pixelcopy_t *, uint32_t) override {}
+    void writeBytes(const uint8_t *, uint32_t, bool, bool) override {}
+    void initDMA(void) override {}
+    void addDMAQueue(const uint8_t *, uint32_t) override {}
+    void execDMAQueue(void) override {}
+    uint8_t *getDMABuffer(uint32_t) override { return _fbs[0]; }
+    void beginRead(void) override {}
+    void endRead(void) override {}
+    uint32_t readData(uint_fast8_t) override { return 0; }
+    bool readBytes(uint8_t *, uint32_t, bool) override { return false; }
+    void readPixels(void *, pixelcopy_t *, uint32_t) override {}
+
+  private:
+    // MUST be in IRAM: the DPI driver rejects (and does not install) a vsync
+    // callback that isn't, which would leave _vsync ungiven and make present()
+    // block its full timeout every frame — stalling the LVGL/touch task.
+    static bool IRAM_ATTR onRefreshDone(esp_lcd_panel_handle_t, esp_lcd_dpi_panel_event_data_t *, void *ctx)
+    {
+        auto *self = static_cast<Bus_DSI_P4 *>(ctx);
+        BaseType_t hp = pdFALSE;
+        if (self->_vsync)
+            xSemaphoreGiveFromISR(self->_vsync, &hp);
+        return hp == pdTRUE;
+    }
+
+    esp_ldo_channel_handle_t _ldo = nullptr;
+    esp_lcd_dsi_bus_handle_t _dsi_bus = nullptr;
+    esp_lcd_panel_io_handle_t _io = nullptr;
+    esp_lcd_panel_handle_t _panel = nullptr;
+    uint8_t *_fbs[2] = {nullptr, nullptr};
+    uint8_t _back = 1;
+    SemaphoreHandle_t _vsync = nullptr;
+};
+
+// ---------------------------------------------------------------------------
+// Panel: framebuffer rows -> LGFX (identical mechanics to Panel_RGB_P4)
+// ---------------------------------------------------------------------------
+class Panel_DSI_P4 : public Panel_FrameBufferBase
+{
+  public:
+    Panel_DSI_P4(void)
+    {
+        _write_depth = color_depth_t::rgb565_2Byte;
+        _read_depth = color_depth_t::rgb565_2Byte;
+    }
+
+    bool init(bool use_reset) override
+    {
+        if (_lines_buffer)
+            return false;
+        if (!Panel_FrameBufferBase::init(use_reset))
+            return false;
+        _dsibus = static_cast<Bus_DSI_P4 *>(_bus);
+        if (_dsibus == nullptr || _dsibus->getDMABuffer(0) == nullptr)
+            return false;
+        // Rows kept coherent with the PHYSICAL framebuffer stride so stray
+        // base-class writes stay sane; the LVGL flush path goes through our
+        // scaling writeImage override and never uses them.
+        size_t line_array_size = _cfg.panel_height * sizeof(void *);
+        auto line_array = static_cast<uint8_t **>(heap_alloc_dma(line_array_size));
+        if (line_array == nullptr)
+            return false;
+        memset(line_array, 0, line_array_size);
+        auto fb8 = reinterpret_cast<uint8_t *>(_dsibus->getDMABuffer(0));
+        for (uint16_t y = 0; y < _cfg.panel_height; ++y) {
+            line_array[y] = fb8;
+            fb8 += TDP4_PANEL_W * 2;
+        }
+        _lines_buffer = line_array;
+        return true;
+    }
+
+    // LVGL flush lands here (lgfx->pushImage -> writeImage). Native 1:1: copy
+    // the rgb565 source straight into the off-screen DSI buffer at (x,y) — no
+    // scaling, so the render stays pixel-perfect. present() swaps it on vsync.
+    void writeImage(uint_fast16_t x, uint_fast16_t y, uint_fast16_t w, uint_fast16_t h, pixelcopy_t *param,
+                    bool use_dma) override
+    {
+        (void)use_dma;
+        uint16_t *_fb = _dsibus ? _dsibus->backbuf() : nullptr;
+        if (_fb == nullptr || param == nullptr || param->src_data == nullptr || x >= TDP4_PANEL_W)
+            return;
+        auto src = static_cast<const uint16_t *>(param->src_data);
+        const uint32_t pitch = param->src_bitwidth ? param->src_bitwidth : w;
+        const uint32_t sxoff = param->src_x, syoff = param->src_y;
+        uint32_t ww = w;
+        if (x + ww > TDP4_PANEL_W)
+            ww = TDP4_PANEL_W - x;
+        for (uint32_t sy = 0; sy < h; ++sy) {
+            uint32_t gy = y + sy;
+            if (gy >= TDP4_PANEL_H)
+                break;
+            const uint16_t *srow = src + (sy + syoff) * pitch + sxoff;
+            memcpy(_fb + gy * TDP4_PANEL_W + x, srow, ww * sizeof(uint16_t));
+        }
+    }
+
+    void writeFillRectPreclipped(uint_fast16_t x, uint_fast16_t y, uint_fast16_t w, uint_fast16_t h,
+                                 uint32_t rawcolor) override
+    {
+        uint16_t *_fb = _dsibus ? _dsibus->backbuf() : nullptr;
+        if (_fb == nullptr || x >= TDP4_PANEL_W || y >= TDP4_PANEL_H)
+            return;
+        uint32_t dx1 = x + w, dy1 = y + h;
+        if (dx1 > TDP4_PANEL_W)
+            dx1 = TDP4_PANEL_W;
+        if (dy1 > TDP4_PANEL_H)
+            dy1 = TDP4_PANEL_H;
+        const uint16_t c = static_cast<uint16_t>(rawcolor);
+        for (uint32_t dy = y; dy < dy1; ++dy) {
+            uint16_t *drow = _fb + dy * TDP4_PANEL_W;
+            for (uint32_t dx = x; dx < dx1; ++dx)
+                drow[dx] = c;
+        }
+    }
+
+    // Called by the LVGL flush path once all of a frame's pixels are composed
+    // into the back buffer: swap it on screen atomically.
+    void present(void)
+    {
+        if (_dsibus)
+            _dsibus->present();
+    }
+
+    color_depth_t setColorDepth(color_depth_t) override { return _write_depth; }
+    void writeCommand(uint32_t, uint_fast8_t) override {}
+    void writeData(uint32_t, uint_fast8_t) override {}
+
+  private:
+    Bus_DSI_P4 *_dsibus = nullptr;
+};
