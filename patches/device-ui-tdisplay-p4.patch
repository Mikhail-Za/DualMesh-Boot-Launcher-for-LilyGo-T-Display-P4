+// LovyanGFX device for the LilyGo T-Display P4 TFT SKU (HI8561, MIPI-DSI
+// 540x1168) for use with meshtastic device-ui (MUI).
+//
+// Pattern follows device-ui's experimental esp32p4 classes (Bus_RGB_P4 /
+// Panel_RGB_P4): LovyanGFX renders into the esp_lcd framebuffer that the
+// hardware scans out autonomously; the IBus is a stub that owns the esp_lcd
+// objects. Here the scanout engine is the P4's MIPI-DSI DPI mode instead of
+// the RGB peripheral.
+//
+// Hardware facts (LilyGo T-Display-P4 debug2 driver, all board-verified):
+//   panel 540x1168 @ DPI 60MHz, 2 data lanes @ 1000 Mbps,
+//   HSYNC 28 / HBP 26 / HFP 20, VSYNC 2 / VBP 22 / VFP 200,
+//   MIPI PHY LDO channel 3 @ 1830 mV (LilyGo runs the MIPI domain at 1.8V),
+//   backlight PWM on GPIO 51 (2 kHz), touch controller at I2C 0x68
+//   (memory-mapped reads: 0xF3 + addr32be + 0x03), panel/touch reset on the
+//   XL9535 expander (pulsed by initVariant() in variant.cpp before we run).
+#pragma once
+
+#define LGFX_USE_V1
+#include <LovyanGFX.hpp>
+
+#include <Arduino.h>
+#include <esp_lcd_mipi_dsi.h>
+#include <esp_lcd_panel_io.h>
+#include <esp_lcd_panel_ops.h>
+#include <esp_ldo_regulator.h>
+#include <esp_log.h>
+
+#include "driver/i2c_master.h"
+#include "lgfx/v1/Bus.hpp"
+#include "lgfx/v1/panel/Panel_FrameBufferBase.hpp"
+
+#if !defined(CONFIG_IDF_TARGET_ESP32P4) && !defined(__INTELLISENSE__)
+#error "CONFIG_IDF_TARGET_ESP32P4 should be set"
+#endif
+
+// I2C master bus owned by initVariant() (XL9535 lives there too) — the touch
+// controller shares it.
+extern i2c_master_bus_handle_t tdp4_i2c_bus;
+
+#define TDP4_PANEL_W 540
+#define TDP4_PANEL_H 1168
+#define TDP4_BL_PIN 51
+
+namespace lgfx
+{
+inline namespace v1
+{
+
