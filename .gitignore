# Licensed/extracted binaries and full flash dumps — never version, never publish.
# MeshOS is Andy Kirby's closed-source licensed firmware; the dump contains it.
backups/

# External clones (LilyGo SDK + reference ports) — patches/ captures our changes
T-Display-P4/
reference/

# Build output
launcher/build/
launcher/managed_components/
launcher/dependencies.lock

# Generated config (sdkconfig.defaults is the source of truth)
launcher/sdkconfig
launcher/sdkconfig.old
meshtastic-firmware/

# c6-updater build output + extracted LilyGo slave image (regenerate with
# tools/extract-c6-app.ps1 from the T-Display-P4 clone)
c6-updater/build/
c6-updater/managed_components/
c6-updater/dependencies.lock
c6-updater/sdkconfig
c6-updater/sdkconfig.old
c6-updater/main/slave_fw.bin

__pycache__/
notes/*-capture.txt
notes/c6upd-*.txt
c6-ota-serve/
notes/at-scout.txt
